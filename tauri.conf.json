{
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "http://localhost:8080",
    "distDir": "./ui"
  },
  "package": {
    "productName": "Viceroy",
    "version": "0.1.0"
  },
  "tauri": {
    "macOSPrivateApi": true,
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "dialog": {
        "all": false,
        "open": true
      },
      "fs": {
        "all": false,
        "readDir": true,
        "scope": ["$HOME/**"]
      },
      "globalShortcut": {
        "all": true
      },
      "window": {
        "all": false,
        "show": true,
        "hide": true,
        "close": true,
        "setFocus": true
      }
    },
    "systemTray": {
      "iconPath": "icons/icon-tray.png"
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.viceroy.app",
      "icon": [
        "icons/icon.icns"
      ],
      "macOS": {
        "minimumSystemVersion": "10.15"
      }
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "Viceroy",
        "width": 800,
        "height": 660,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "center": true,
        "skipTaskbar": true,
        "visible": false
      }
    ]
  }
}
