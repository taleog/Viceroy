<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Viceroy</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            background: rgba(30, 30, 30, 0.95);
            color: #d4d4d4;
            overflow: hidden;
            -webkit-app-region: drag;
        }

        #app {
            width: 800px;
            height: 600px;
            display: flex;
            flex-direction: column;
            padding: 20px;
        }

        #search-container {
            -webkit-app-region: no-drag;
            margin-bottom: 20px;
        }

        #search-input {
            width: 100%;
            padding: 15px 20px;
            font-size: 18px;
            border: none;
            border-radius: 10px;
            background: rgba(60, 60, 60, 0.8);
            color: #d4d4d4;
            outline: none;
            transition: background 0.2s;
        }

        #search-input:focus {
            background: rgba(70, 70, 70, 0.9);
        }

        #results-container {
            flex: 1;
            overflow-y: auto;
            -webkit-app-region: no-drag;
        }

        .result-item {
            padding: 12px 16px;
            margin-bottom: 8px;
            background: rgba(60, 60, 60, 0.6);
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .result-item:hover,
        .result-item.selected {
            background: rgba(0, 122, 204, 0.4);
            transform: translateX(4px);
        }

        .result-icon {
            width: 32px;
            height: 32px;
            border-radius: 6px;
            background: rgba(0, 122, 204, 0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
        }

        .result-content {
            flex: 1;
            min-width: 0;
        }

        .result-title {
            font-size: 14px;
            font-weight: 500;
            color: #fff;
            margin-bottom: 4px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .result-subtitle {
            font-size: 12px;
            color: #999;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .result-type {
            padding: 4px 8px;
            background: rgba(0, 122, 204, 0.3);
            border-radius: 4px;
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        #loading {
            text-align: center;
            padding: 40px;
            color: #666;
            display: none;
        }

        #empty-state {
            text-align: center;
            padding: 60px 40px;
            color: #666;
        }

        #empty-state h2 {
            font-size: 24px;
            margin-bottom: 12px;
            color: #999;
        }

        #empty-state p {
            font-size: 14px;
        }

        ::-webkit-scrollbar {
            width: 8px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        ::-webkit-scrollbar-thumb {
            background: rgba(100, 100, 100, 0.5);
            border-radius: 4px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: rgba(120, 120, 120, 0.7);
        }

        .calculator-formats {
            display: flex;
            flex-direction: column;
            gap: 4px;
            font-family: 'Monaco', 'Menlo', monospace;
            font-size: 12px;
        }

        .calculator-format {
            color: #888;
        }

        .calculator-format strong {
            color: #007acc;
            margin-right: 8px;
        }
    </style>
</head>
<body>
    <div id="app">
        <div id="search-container">
            <input 
                type="text" 
                id="search-input" 
                placeholder="Search apps, files, clipboard..." 
                autocomplete="off"
                spellcheck="false"
            />
        </div>
        
        <div id="results-container">
            <div id="empty-state">
                <h2>Viceroy</h2>
                <p>Start typing to search apps, files, clipboard history, and more...</p>
                <p style="margin-top: 20px; font-size: 12px;">Press <strong>Esc</strong> to close</p>
            </div>
            <div id="loading">Searching...</div>
        </div>
    </div>

    <script>
        // Initialize when DOM and Tauri are ready
        window.addEventListener('DOMContentLoaded', () => {
            console.log('DOMContentLoaded, checking Tauri...', !!window.__TAURI__);
            
            if (!window.__TAURI__) {
                console.error('Tauri not available!');
                document.body.innerHTML = '<div style="padding: 40px; text-align: center; color: #f44;">Error: Tauri API not available. Please run in Tauri context.</div>';
                return;
            }
            
            console.log('Tauri available, initializing...');
            initApp();
        });

        function initApp() {
            const { invoke } = window.__TAURI__.tauri;
            const { appWindow } = window.__TAURI__.window;
            
            console.log('App initialized with Tauri functions');

            const searchInput = document.getElementById('search-input');
            const resultsContainer = document.getElementById('results-container');
            const emptyState = document.getElementById('empty-state');
            const loading = document.getElementById('loading');

            let selectedIndex = 0;
            let searchResults = [];
            let debounceTimer = null;

            // Focus input on load
            searchInput.focus();

        // Search with debounce
        searchInput.addEventListener('input', (e) => {
            clearTimeout(debounceTimer);
            
            if (e.target.value.trim() === '') {
                showEmptyState();
                return;
            }

            loading.style.display = 'block';
            emptyState.style.display = 'none';

            debounceTimer = setTimeout(async () => {
                await performSearch(e.target.value);
            }, 150);
        });

        // Keyboard navigation
        searchInput.addEventListener('keydown', async (e) => {
            if (e.key === 'Escape') {
                e.preventDefault();
                try {
                    await appWindow.hide();
                    searchInput.value = '';
                    showEmptyState();
                } catch (err) {
                    console.error('Failed to hide window:', err);
                }
            } else if (e.key === 'ArrowDown') {
                e.preventDefault();
                selectedIndex = Math.min(selectedIndex + 1, searchResults.length - 1);
                updateSelection();
            } else if (e.key === 'ArrowUp') {
                e.preventDefault();
                selectedIndex = Math.max(selectedIndex - 1, 0);
                updateSelection();
            } else if (e.key === 'Enter') {
                e.preventDefault();
                if (searchResults.length > 0) {
                    await executeResult(searchResults[selectedIndex]);
                }
            }
        });

        async function performSearch(query) {
            try {
                console.log('Searching for:', query);
                const results = await invoke('search', { query });
                console.log('Search results:', results);
                searchResults = results;
                selectedIndex = 0;
                displayResults(results);
            } catch (error) {
                console.error('Search error:', error);
                resultsContainer.innerHTML = `<div style="text-align: center; padding: 40px; color: #f44;">Error: ${error}</div>`;
                loading.style.display = 'none';
            }
        }

        function displayResults(results) {
            loading.style.display = 'none';
            
            if (results.length === 0) {
                resultsContainer.innerHTML = '<div style="text-align: center; padding: 40px; color: #666;">No results found</div>';
                return;
            }

            resultsContainer.innerHTML = results.map((result, index) => {
                return createResultHTML(result, index);
            }).join('');

            // Add click handlers
            const items = resultsContainer.querySelectorAll('.result-item');
            items.forEach((item, index) => {
                item.addEventListener('click', () => executeResult(results[index]));
            });
        }

        function createResultHTML(result, index) {
            const selected = index === selectedIndex ? 'selected' : '';
            
            if (result.type === 'App') {
                return `
                    <div class="result-item ${selected}" data-index="${index}">
                        <div class="result-icon">📦</div>
                        <div class="result-content">
                            <div class="result-title">${escapeHtml(result.name)}</div>
                            <div class="result-subtitle">${escapeHtml(result.path)}</div>
                        </div>
                        <div class="result-type">App</div>
                    </div>
                `;
            } else if (result.type === 'File') {
                return `
                    <div class="result-item ${selected}" data-index="${index}">
                        <div class="result-icon">📄</div>
                        <div class="result-content">
                            <div class="result-title">${escapeHtml(result.name)}</div>
                            <div class="result-subtitle">${escapeHtml(result.path)}</div>
                        </div>
                        <div class="result-type">File</div>
                    </div>
                `;
            } else if (result.type === 'Clipboard') {
                return `
                    <div class="result-item ${selected}" data-index="${index}">
                        <div class="result-icon">📋</div>
                        <div class="result-content">
                            <div class="result-title">${escapeHtml(result.preview)}</div>
                            <div class="result-subtitle">${result.app_name ? escapeHtml(result.app_name) : 'Unknown app'}</div>
                        </div>
                        <div class="result-type">Clipboard</div>
                    </div>
                `;
            } else if (result.type === 'Command') {
                return `
                    <div class="result-item ${selected}" data-index="${index}">
                        <div class="result-icon">⚡</div>
                        <div class="result-content">
                            <div class="result-title">${escapeHtml(result.name)}</div>
                            <div class="result-subtitle">${escapeHtml(result.description)}</div>
                        </div>
                        <div class="result-type">Command</div>
                    </div>
                `;
            } else if (result.type === 'Calculator') {
                return `
                    <div class="result-item ${selected}" data-index="${index}">
                        <div class="result-icon">🔢</div>
                        <div class="result-content">
                            <div class="result-title">${escapeHtml(result.expression)} = ${escapeHtml(result.result)}</div>
                            <div class="calculator-formats">
                                ${result.formats.slice(1).map(fmt => `<div class="calculator-format">${escapeHtml(fmt)}</div>`).join('')}
                            </div>
                        </div>
                        <div class="result-type">Calculator</div>
                    </div>
                `;
            }
            
            return '';
        }

        function updateSelection() {
            const items = resultsContainer.querySelectorAll('.result-item');
            items.forEach((item, index) => {
                if (index === selectedIndex) {
                    item.classList.add('selected');
                    item.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
                } else {
                    item.classList.remove('selected');
                }
            });
        }

        async function executeResult(result) {
            try {
                if (result.type === 'App') {
                    await invoke('launch_app', { bundlePath: result.path });
                } else if (result.type === 'File') {
                    await invoke('open_file', { path: result.path });
                } else if (result.type === 'Clipboard') {
                    // Copy to clipboard
                    navigator.clipboard.writeText(result.content);
                } else if (result.type === 'Command') {
                    await invoke('execute_system_command', { command: result.command });
                } else if (result.type === 'Calculator') {
                    navigator.clipboard.writeText(result.result);
                }
                
                // Hide window after execution
                await invoke('hide_window');
                searchInput.value = '';
                showEmptyState();
            } catch (error) {
                console.error('Execution error:', error);
            }
        }

        function showEmptyState() {
            emptyState.style.display = 'block';
            loading.style.display = 'none';
            resultsContainer.innerHTML = '';
            resultsContainer.appendChild(emptyState);
            resultsContainer.appendChild(loading);
            searchResults = [];
            selectedIndex = 0;
        }

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        // Handle window visibility
        document.addEventListener('visibilitychange', () => {
            if (document.hidden) {
                searchInput.value = '';
                showEmptyState();
            } else {
                searchInput.focus();
            }
        });

        // Hide window when it loses focus
        let blurTimeout;
        window.addEventListener('blur', () => {
            // Use timeout to prevent hiding when clicking within the window
            blurTimeout = setTimeout(async () => {
                try {
                    await appWindow.hide();
                    searchInput.value = '';
                    showEmptyState();
                } catch (e) {
                    console.log('Hide window error:', e);
                }
            }, 200);
        });
        
        window.addEventListener('focus', () => {
            clearTimeout(blurTimeout);
        });
        
        // Log for debugging
        console.log('Viceroy UI initialized');
        
        // Test Tauri connection
        if (window.__TAURI__) {
            console.log('Tauri API available');
        } else {
            console.error('Tauri API not available - check devPath in tauri.conf.json');
        }
    </script>
</body>
</html>
