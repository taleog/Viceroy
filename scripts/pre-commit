#!/bin/bash
# Pre-commit hook for Viceroy
# Validates and optionally updates documentation before commits

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo -e "${YELLOW}Running pre-commit checks...${NC}"

# Check if Cargo.toml version matches build_app.sh VERSION
CARGO_VERSION=$(grep '^version = ' Cargo.toml | head -1 | sed 's/version = "\(.*\)"/\1/')
BUILD_VERSION=$(grep '^VERSION=' build_app.sh | sed 's/VERSION="\(.*\)"/\1/')

if [ -n "$BUILD_VERSION" ] && [ "$CARGO_VERSION" != "$BUILD_VERSION" ]; then
    echo -e "${YELLOW}Note: Cargo.toml version ($CARGO_VERSION) differs from build_app.sh VERSION ($BUILD_VERSION)${NC}"
    echo -e "${YELLOW}Consider updating build_app.sh to use Cargo version${NC}"
fi

# Check for CHANGELOG.md updates when there are code changes
STAGED_RS_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep '\.rs$' || true)
CHANGELOG_STAGED=$(git diff --cached --name-only | grep 'CHANGELOG.md' || true)

if [ -n "$STAGED_RS_FILES" ] && [ -z "$CHANGELOG_STAGED" ]; then
    echo -e "${YELLOW}Warning: Rust files changed but CHANGELOG.md not updated${NC}"
    echo -e "${YELLOW}Consider adding your changes under [Unreleased] in CHANGELOG.md${NC}"
fi

# Run cargo fmt check
echo "Checking code formatting..."
if ! cargo fmt --all -- --check 2>/dev/null; then
    echo -e "${RED}Error: Code formatting issues found${NC}"
    echo "Run 'cargo fmt' to fix formatting"
    exit 1
fi
echo -e "${GREEN}✓ Formatting OK${NC}"

# Run clippy (warnings as errors)
echo "Running clippy..."
if ! cargo clippy --all-targets --all-features -- -D warnings 2>/dev/null; then
    echo -e "${RED}Error: Clippy warnings found${NC}"
    echo "Fix the warnings before committing"
    exit 1
fi
echo -e "${GREEN}✓ Clippy OK${NC}"

# Auto-update documentation timestamp
if [ -f "docs/roadmap.md" ]; then
    # Update last modified date in roadmap if it exists
    TODAY=$(date +%Y-%m-%d)
    if grep -q "Last updated:" docs/roadmap.md; then
        sed -i.bak "s/Last updated:.*/Last updated: $TODAY/" docs/roadmap.md
        rm -f docs/roadmap.md.bak
        git add docs/roadmap.md
    fi
fi

echo -e "${GREEN}✓ All pre-commit checks passed!${NC}"
exit 0
